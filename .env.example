# =============================================================================
# CueAPI Core — Environment Variables
# Copy this file to .env and update the values
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://cueapi:password@localhost:5432/cueapi

# Redis
REDIS_URL=redis://localhost:6379

# Security — CHANGE THESE before deploying to production
SESSION_SECRET=change-this-to-a-long-random-string

# API configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# Registration — set to false in production to disable open registration
ALLOW_REGISTER=true

# Webhook delivery
WEBHOOK_TIMEOUT_SECONDS=30

# Poller configuration
POLLER_INTERVAL_SECONDS=5
POLLER_BATCH_SIZE=500

# Worker configuration
WORKER_HEARTBEAT_TIMEOUT_SECONDS=180
WORKER_CLAIM_TIMEOUT_SECONDS=900
WORKER_UNCLAIMED_TIMEOUT_SECONDS=900

# Email notifications (optional — leave empty to log to stdout in dev)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=CueAPI <noreply@yourdomain.com>
